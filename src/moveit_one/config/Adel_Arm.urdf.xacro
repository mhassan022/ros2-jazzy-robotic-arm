<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Adel_Arm">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import Adel_Arm urdf file -->
    <xacro:include filename="$(find Adel_Arm)/urdf/Adel_Arm.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="Adel_Arm.ros2_control.xacro" />


    <xacro:Adel_Arm_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
